# Kickstart configuration for {{ config.client_name.long }}
# Generated by potos-iso-builder on {{ build_date }}
# ref: https://pykickstart.readthedocs.io/en/latest/kickstart-docs.html

# Configure repositories
url --mirrorlist="https://mirrors.fedoraproject.org/mirrorlist?repo=fedora-{{ config.fedora_version }}&arch=x86_64"
repo --name=fedora-updates --mirrorlist="https://mirrors.fedoraproject.org/mirrorlist?repo=updates-released-f{{ config.fedora_version }}&arch=x86_64" --cost=0
{% for repo in config.extra_repos %}
{% if repo.mirrorlist is defined %}
repo --name={{ repo.name }}{% if repo.install | default(false) %} --install{% endif %} --mirrorlist="{{ repo.mirrorlist | replace('{version}', config.fedora_version | string) }}"{% if repo.cost is defined %} --cost={{ repo.cost }}{% endif %}

{% elif repo.baseurl is defined %}
repo --name={{ repo.name }}{% if repo.install | default(false) %} --install{% endif %} --baseurl="{{ repo.baseurl }}"{% if repo.cost is defined %} --cost={{ repo.cost }}{% endif %}

{% endif %}
{% endfor %}

# Remove all existing partitions
clearpart --all --initlabel

# Partitioning
{% if config.disk_encryption.enabled %}
autopart --encrypted --passphrase={{ config.disk_encryption.init_password }} --type={{ config.partitioning.type }}
{% else %}
autopart --type={{ config.partitioning.type }}
{% endif %}

# Configure Firewall
{% if config.firewall.enabled %}
firewall --enabled
{% else %}
firewall --disabled
{% endif %}

# Locale settings
{% if config.locale.lang %}
lang {{ config.locale.lang }}
{% endif %}
{% if config.locale.keyboard %}
keyboard {{ config.locale.keyboard }}
{% endif %}

# Timezone
{% if config.locale.timezone %}
timezone {{ config.locale.timezone }}
{% endif %}

# Networking
network --bootproto={{ config.network.bootproto }} --device={{ config.network.device }}{% if config.network.activate %} --activate{% endif %} --onboot=yes
network --hostname={{ config.initial_hostname }}

# Root password (locked)
rootpw --lock

{% if config.initial_user.username %}
# Create initial user
{% if config.initial_user.password_hash %}
user --name={{ config.initial_user.username }} --password={{ config.initial_user.password_hash }} --iscrypted --groups=wheel
{% else %}
user --name={{ config.initial_user.username }} --groups=wheel
{% endif %}
{% endif %}

# Authselect
{% for feature in config.authselect.features %}
authselect enable-feature {{ feature }}
{% endfor %}

# Perform Installation in graphical Mode
graphical

# Package Selection
%packages
{% for pkg in config.packages.exclude %}
-{{ pkg }}
{% endfor %}
{% for group in config.packages.groups %}
@{{ group }}
{% endfor %}
{% for pkg in config.packages.install %}
{{ pkg }}
{% endfor %}

# we dont want any initial setup tooling or welcoming wizards
-gnome-tour
-gnome-initial-setup
-initial-setup

%end

# Post-install action
{% if config.post_install == 'reboot' %}
reboot
{% elif config.post_install == 'reboot_eject' %}
reboot --eject
{% elif config.post_install == 'shutdown_eject' %}
shutdown --eject
{% else %}
shutdown
{% endif %}


# Post-install scripts to bootstap the firstboot wizard
%post --nochroot --log=/mnt/sysimage/root/potos-stage.log
set -eu
if [ -d /run/install/repo/setup ]; then
  mkdir -p /mnt/sysimage/root/potos-setup
  cp -a /run/install/repo/setup/. /mnt/sysimage/root/potos-setup/
else
  echo "WARN: /run/install/repo/setup not found - nothing to stage" >&2
fi
%end

%post --log=/root/potos-post-install.log
{{ post_scripts }}
%end
